      <div id="financial-detail-content" class="space-y-4">
      </div>

      <div class="flex gap-2 justify-end mt-6 pt-4 border-t border-borderLight">
        <button onclick="closeFinancialDetailModal()" class="border border-borderDark px-4 py-1.5 font-mono text-xs uppercase font-bold text-gray-500 hover:text-dark transition-colors">
          Close
        </button>
        <button id="mark-paid-btn" class="bg-green-600 text-white px-4 py-1.5 font-display text-xs tracking-wider font-bold uppercase brutal-clip hover:bg-green-700 transition-all">
          Mark as Paid
        </button>
      </div>
