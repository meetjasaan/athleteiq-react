  <div id="financial-detail-modal" class="hidden fixed inset-0 bg-dark/80 backdrop-blur-sm justify-center items-center z-50 p-4">
    <div class="bg-white border-2 border-dark p-6 max-w-lg w-full brutal-clip shadow-xl max-h-[80vh] overflow-y-auto">
      <div class="flex justify-between items-center mb-4 pb-3 border-b border-borderLight">
