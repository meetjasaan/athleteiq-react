        <button onclick="changeSubscriptionTier('TIER_1'); closePlanModal();" class="w-full text-left p-3 border border-borderLight hover:bg-clinical transition-colors font-mono text-xs">
          <div class="font-bold text-dark">Small Club — $249/month</div>
          <div class="text-gray-500 text-[10px]">Up to 24 players</div>
        </button>
        <button onclick="changeSubscriptionTier('TIER_2'); closePlanModal();" class="w-full text-left p-3 border-2 border-brand bg-brand/5 hover:bg-brand/10 transition-colors font-mono text-xs">
