            </div>

            <form id="add-player-form" onsubmit="createNewAthlete(event)" class="grid grid-cols-1 sm:grid-cols-3 gap-3 items-end mb-6">
              <div class="sm:col-span-2">
                <label class="block font-mono text-[10px] text-gray-500 uppercase font-bold mb-1">Player Full Name</label>
                <input type="text" id="new-p-name" required placeholder="Ex: Noah Dabney" class="w-full bg-clinical border border-borderDark px-3 py-2 text-xs outline-none focus:border-brand">
              </div>
              <div class="flex flex-col gap-3 sm:flex-row sm:col-span-1">
                <div class="w-full">
                  <label class="block font-mono text-[10px] text-gray-500 uppercase font-bold mb-1">Date of Birth</label>
                  <input type="date" id="new-p-dob" required class="w-full bg-clinical border border-borderDark px-3 py-2 font-mono text-xs outline-none focus:border-brand">
                </div>
                <button type="submit" id="new-p-btn" class="w-full sm:w-auto shrink-0 bg-dark text-white font-display text-xs uppercase font-black tracking-wider px-4 py-2.5 hover:bg-brand hover:text-dark transition-all brutal-clip">
                  Save Player
                </button>
              </div>
            </form>

            <div class="pt-4 border-t border-dashed border-borderLight">
              <button type="button" onclick="openAdminStubModal()" class="text-dark border border-dark px-3 py-1.5 bg-white text-[10px] font-bold hover:bg-dark hover:text-white transition-colors">
                + Add as Admin Stub
              </button>
              <p class="text-[9px] text-gray-400 mt-1">Add players without parent info yet. Complete their profile when they sign up.</p>
