  <!-- ADMIN ROSTER STUB MODAL -->
  <div id="admin-stub-modal" class="hidden fixed inset-0 bg-dark/80 backdrop-blur-sm justify-center items-center z-50 p-4">
    <div class="bg-white border-2 border-dark p-6 max-w-md w-full brutal-clip shadow-xl">
      <h3 class="font-display text-lg font-black uppercase text-dark mb-4">Add Player (Admin)</h3>
      <form onsubmit="createAdminStub(event)" class="space-y-3">
        <div>
          <label class="block font-mono text-[10px] text-gray-500 uppercase font-bold mb-1">Player Full Name</label>
          <input type="text" id="stub-player-name" required placeholder="Noah Dabney" class="w-full border border-borderLight bg-clinical px-3 py-2 text-xs outline-none focus:border-brand">
        </div>
        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="block font-mono text-[10px] text-gray-500 uppercase font-bold mb-1">Jersey #</label>
            <input type="text" id="stub-player-jersey" placeholder="0-99" class="w-full border border-borderLight bg-clinical px-3 py-2 text-xs outline-none focus:border-brand">
          </div>
          <div>
            <label class="block font-mono text-[10px] text-gray-500 uppercase font-bold mb-1">Position</label>
            <input type="text" id="stub-player-pos" placeholder="Guard" class="w-full border border-borderLight bg-clinical px-3 py-2 text-xs outline-none focus:border-brand">
          </div>
        </div>
        <div>
          <label class="block font-mono text-[10px] text-gray-500 uppercase font-bold mb-1">Age Group</label>
          <select id="stub-player-division" required class="w-full border border-borderLight bg-clinical px-3 py-2 text-xs outline-none focus:border-brand"></select>
        </div>
        <div class="bg-blue-50 border border-blue-200 p-2.5 rounded text-[9px] text-blue-900">
          This player will be set as "Administrative Pending" until a parent email is added.
        </div>
        <div class="flex gap-2 justify-end">
          <button type="button" onclick="closeAdminStubModal()" class="border border-borderDark px-4 py-1.5 font-mono text-xs uppercase font-bold text-gray-500 hover:text-dark transition-colors">
            Cancel
          </button>
          <button type="submit" class="bg-dark text-white px-4 py-1.5 font-display text-xs tracking-wider font-bold uppercase brutal-clip hover:bg-brand hover:text-dark transition-all">
            Add Stub
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- BALANCE OVERRIDE MODAL -->
  <div id="destruction-modal-layer" class="fixed inset-0 bg-dark/80 backdrop-blur-sm items-center justify-center z-50 p-4 hidden">
    <div class="bg-white border-2 border-dark p-6 max-w-md w-full brutal-clip shadow-xl">
      <div class="flex items-start gap-3 mb-4">
        <div>
          <h4 class="font-display text-lg font-black uppercase tracking-tight">Manual Balance Override</h4>
          <p class="font-mono text-[10px] text-gray-400">Direct account balance adjustment route</p>
        </div>
      </div>
      <p class="font-body text-xs text-gray-600 mb-5">
        You are overriding a balance due on this player's account. This will change the amount reflected in your league financials and player invoices.
      </p>
      <div class="bg-clinical border border-borderLight p-3 font-mono text-[10px] text-dark mb-5 space-y-1">
        <div>Action: <span id="modal-lbl-action" class="font-bold text-amber-600">N/A</span></div>
        <div>Player: <span id="modal-lbl-name" class="font-bold">N/A</span></div>
        <div class="mt-2">
          <label class="block font-bold mb-1">New Adjusted Value ($)</label>
          <input type="number" id="modal-override-input" step="0.01" class="w-full bg-white border border-borderDark p-1 font-mono text-xs font-bold text-dark outline-none focus:border-brand">
        </div>
      </div>
      <div class="flex gap-2 justify-end">
        <button onclick="dismissOverrideModal()" class="border border-borderDark px-4 py-1.5 font-mono text-xs uppercase font-bold text-gray-500 hover:text-dark transition-colors">
          Cancel
        </button>
        <button onclick="commitOverrideModal()" class="bg-dark text-white px-4 py-1.5 font-display text-xs tracking-wider font-bold uppercase brutal-clip hover:bg-brand hover:text-dark transition-all">
          Apply Adjustment
        </button>
      </div>
    </div>
  </div>

  <!-- APP RUNTIME SCRIPTS -->
  <script>
    const DIVISION_NODES = ['8U', '9U', '10U', '11U', '12U', '13U', '14U', '15U', '16U', '17U'];
    let selectedDivisionsForEvent = ['9U'];

    function switchDirectorTab(tabId) {
      STATE.directorTab = tabId;
      document.querySelectorAll('.dir-tab-panel').forEach(p => p.classList.add('hidden'));
      const activePanel = document.getElementById(`dir-content-${tabId}`);
      if (activePanel) activePanel.classList.remove('hidden');

      document.querySelectorAll('[id^="tab-"]').forEach(btn => {
        btn.className = "w-full text-left px-3 py-2.5 transition-all flex items-center justify-between text-gray-400 hover:text-dark hover:bg-white/50";
      });
      const activeBtn = document.getElementById(`tab-${tabId}`);
      if (activeBtn) {
        activeBtn.className = "w-full text-left px-3 py-2.5 transition-all flex items-center justify-between text-dark bg-white shadow-sm border-l-4 border-brand font-black";
      }

      document.querySelectorAll('[id^="mobile-tab-"]').forEach(btn => {
        btn.className = "w-full text-left px-3 py-2.5 transition-all text-gray-400";
      });
      const activeMobileBtn = document.getElementById(`mobile-tab-${tabId}`);
      if (activeMobileBtn) {
        activeMobileBtn.className = "w-full text-left px-3 py-2.5 transition-all text-dark font-black bg-white/50";
      }

      const mobileNav = document.getElementById('mobile-sidebar');
      if (mobileNav && window.innerWidth < 1024) {
        mobileNav.classList.add('hidden');
      }
    }

    function addDivision() {
      const newDiv = prompt('Enter new division name (e.g., 18U, 19U):');
      if (newDiv && !DIVISION_NODES.includes(newDiv)) {
        DIVISION_NODES.push(newDiv);
        STATE.activeDivisions.push(newDiv);
        renderProgramsTabMatrix();
        refreshEventMatrixUI();
        alert(`Division "${newDiv}" has been added.`);
      }
    }

    function filterRoster() {
      STATE.rosterSearch = document.getElementById('roster-search').value.toLowerCase();
      renderRosterTabList();
    }

    function filterMembers() {
      STATE.membersSearch = document.getElementById('members-search').value.toLowerCase();
      renderMembersTabDirectory();
    }

    function renderDirectorDashboard() {
      document.getElementById('slug-badge').innerText = `[${STATE.clubSlug.toUpperCase()}]`;
      document.getElementById('tier-badge-ui').innerText = getTierName(STATE.currentTier);
      document.getElementById('demo-count').innerText = `${STATE.players.length} Players Total`;

      const capLimit = getTierCap(STATE.currentTier);

      document.getElementById('stat-active-count').innerText = STATE.players.length;
      document.getElementById('stat-bracket-cap').innerText = capLimit;

      const indicator = document.getElementById('tab-roster-cap-indicator');
      if (indicator) {
        indicator.innerText = `[${STATE.players.length}/${capLimit}]`;
        if (STATE.players.length >= capLimit) {
          indicator.className = "text-[10px] font-bold text-red-600 tracking-tight";
        } else {
          indicator.className = "text-[10px] font-normal text-gray-400 tracking-tight";
        }
      }

      const inputFieldsLocked = STATE.players.length >= capLimit;
      const warningBanner = document.getElementById('bracket-cap-warning');
      if (warningBanner) {
        warningBanner.classList.toggle('hidden', !inputFieldsLocked);
      }

      const nameInput = document.getElementById('new-p-name');
      const dobInput = document.getElementById('new-p-dob');
      const submitBtn = document.getElementById('new-p-btn');

      if (nameInput && dobInput && submitBtn) {
        nameInput.disabled = inputFieldsLocked;
        dobInput.disabled = inputFieldsLocked;
        submitBtn.disabled = inputFieldsLocked;
        if (inputFieldsLocked) {
          nameInput.className = "w-full bg-gray-100 cursor-not-allowed text-gray-400 border border-borderDark px-3 py-2 text-xs outline-none";
          dobInput.className = "w-full bg-gray-100 cursor-not-allowed text-gray-400 border border-borderDark px-3 py-2 font-mono text-xs outline-none";
          submitBtn.className = "w-full sm:w-auto shrink-0 bg-gray-300 text-gray-500 cursor-not-allowed font-display text-xs uppercase font-black tracking-wider px-4 py-2.5 brutal-clip";
        } else {
          nameInput.className = "w-full bg-clinical border border-borderDark px-3 py-2 text-xs outline-none focus:border-brand";
          dobInput.className = "w-full bg-clinical border border-borderDark px-3 py-2 font-mono text-xs outline-none focus:border-brand";
          submitBtn.className = "w-full sm:w-auto shrink-0 bg-dark text-white font-display text-xs uppercase font-black tracking-wider px-4 py-2.5 hover:bg-brand hover:text-dark transition-all brutal-clip";
        }
      }

      renderRosterTabList();
      renderProgramsTabMatrix();
      renderScheduleTabFeed();
      renderMembersTabDirectory();
      renderFinancialsTabLedger();
    }

    function renderRosterTabList() {
      const container = document.getElementById('director-roster-list');
      if(!container) return;
      container.innerHTML = '';

      const filtered = STATE.players.filter(p => p.name.toLowerCase().includes(STATE.rosterSearch));

      if (filtered.length === 0 && STATE.players.length > 0) {
        container.innerHTML = '<div class="text-xs text-gray-400 text-center py-4">No players match your search</div>';
        return;
      }

      if (STATE.players.length === 0) {
        container.innerHTML = '<div class="text-xs text-gray-400 text-center py-8">No players added yet. Use the form above to add your first player.</div>';
        return;
      }

      filtered.forEach(p => {
        const div = document.createElement('div');
        const isStub = p.status === 'Administrative Pending';
        const bgClass = isStub ? 'bg-blue-50' : 'bg-clinical hover:bg-white';
        div.className = `border border-borderLight p-3 flex flex-wrap items-center justify-between gap-2 ${bgClass} text-xs`;
        div.innerHTML = `
          <div class="font-mono">
            <strong class="text-sm font-display uppercase tracking-tight text-dark block">${p.name}</strong>
            <span class="text-gray-400 text-[10px]">Jersey #${p.jersey} | ${p.position} ${p.dob ? `| DOB: ${p.dob}` : '| Profile Pending'}</span>
            <div class="flex gap-1 mt-1">
              ${p.teams.map(t => `<span class="bg-dark text-white text-[9px] px-1 font-bold">${t}</span>`).join('')}
              ${isStub ? `<span class="bg-blue-600 text-white text-[9px] px-1 font-bold">ADMIN STUB</span>` : ''}
            </div>
          </div>
          <div class="flex items-center gap-3 font-mono">
            <div class="text-right">
              <span class="text-[9px] text-gray-400 block">Statement Due</span>
              <strong class="text-dark">${p.balance === 0 ? '$0.00' : `$${p.balance.toFixed(2)}`}</strong>
            </div>
            <button type="button" onclick="launchOverrideModal(${p.id}, '${p.name}', ${p.balance})" class="border border-dark hover:bg-dark hover:text-white px-2 py-1 font-bold text-[10px] uppercase transition-all">
              Override
            </button>
          </div>
        `;
        container.appendChild(div);
      });
    }

    function renderProgramsTabMatrix() {
      const container = document.getElementById('programs-matrix-container');
      if(!container) return;
      container.innerHTML = '';

      STATE.activeDivisions.forEach(divName => {
        const count = STATE.players.filter(p => p.teams.includes(divName)).length;
        const card = document.createElement('div');
        card.className = "border border-borderLight p-3 bg-clinical text-center font-mono";
        card.innerHTML = `
          <div class="font-display font-black text-lg text-dark">${divName}</div>
          <div class="text-[10px] text-gray-400 uppercase mt-0.5">${count} Active</div>
        `;
        container.appendChild(card);
      });
    }

    function renderScheduleTabFeed() {
      const container = document.getElementById('schedule-feed-list');
      if(!container) return;
      container.innerHTML = '';

      if (STATE.events.length === 0) {
        container.innerHTML = '<div class="text-xs text-gray-400 text-center py-4">No events scheduled yet</div>';
        return;
      }

      STATE.events.forEach(evt => {
        const matchesDivision = evt.divisions.some(d => STATE.activeDivisions.includes(d));
        if (!matchesDivision) return;

        const item = document.createElement('div');
        item.className = "border-l-2 border-brand bg-clinical p-2.5 text-xs font-mono flex flex-wrap justify-between items-center gap-2";
        item.innerHTML = `
          <div>
            <div class="font-bold text-dark">${evt.title} [${evt.type}]</div>
            <div class="text-gray-400 text-[10px] mt-0.5">Location: ${evt.location} | ${evt.start} - ${evt.end}</div>
            ${evt.recurring !== 'none' ? `<div class="text-gray-400 text-[10px] mt-0.5">Recurring: ${evt.recurring}</div>` : ''}
          </div>
          <div class="flex gap-1">${evt.divisions.map(d => `<span class="bg-gray-200 text-gray-700 text-[9px] px-1 font-bold">${d}</span>`).join('')}</div>
        `;
        container.appendChild(item);
      });
    }

    function renderMembersTabDirectory() {
      const tbody = document.getElementById('members-table-body');
      if(!tbody) return;
      tbody.innerHTML = '';

      const uniqueParents = [];
      const trackingSet = new Set();

      STATE.players.forEach(p => {
        const pKey = (p.parentName || 'Unknown').toLowerCase();
        if(!trackingSet.has(pKey)) {
          trackingSet.add(pKey);
          uniqueParents.push({
            name: p.parentName || 'Independent Participant',
            role: p.parentName ? 'Parent / Guardian' : 'Independent Athlete',
            athlete: p.name,
            email: p.parentEmail || 'Not provided',
            phone: p.parentPhone || 'Not provided'
          });
        }
      });

      const filtered = uniqueParents.filter(m => m.name.toLowerCase().includes(STATE.membersSearch));

      if (filtered.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" class="p-4 text-center text-xs text-gray-400">No members match your search</td></tr>';
        return;
      }

      filtered.forEach(m => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td class="p-2.5 font-bold text-dark">${m.name}</td>
          <td class="p-2.5">${m.role}</td>
          <td class="p-2.5">${m.athlete}</td>
          <td class="p-2.5 text-gray-500">${m.email}</td>
          <td class="p-2.5 text-gray-500">${m.phone}</td>
        `;
        tbody.appendChild(tr);
      });
    }

    function renderFinancialsTabLedger() {
      const container = document.getElementById('financials-ledger-list');
      const totalDisplay = document.getElementById('stat-unpaid-fees');
      if(!container) return;

      container.innerHTML = '';
      let runningSum = 0;

      if (STATE.players.length === 0) {
        container.innerHTML = '<div class="text-xs text-gray-400 text-center py-6">No player accounts to display</div>';
        if (totalDisplay) totalDisplay.innerText = '$0.00';
        return;
      }

      STATE.players.forEach(p => {
        runningSum += p.balance;
        const line = document.createElement('div');
        line.className = "p-2.5 bg-clinical border border-borderLight flex justify-between items-center text-xs font-mono cursor-pointer hover:bg-white transition-colors";
        line.onclick = () => openFinancialDetailModal(p.id);
        line.innerHTML = `
          <div>
            <span class="font-bold text-dark block">${p.name}</span>
            <span class="text-gray-400 text-[9px]">Club Registration Invoice Status: ${p.paidStatus || 'Pending'}</span>
          </div>
          <strong class="${p.balance > 0 ? 'text-red-700' : 'text-gray-500'}">${p.balance === 0 ? '$0.00' : `$${p.balance.toFixed(2)}`}</strong>
        `;
        container.appendChild(line);
      });

      if(totalDisplay) {
        totalDisplay.innerText = runningSum === 0 ? '$0.00' : `$${runningSum.toFixed(2)}`;
      }
    }

    function renderFinancialDetail(playerId) {
      const player = STATE.players.find(p => p.id === playerId);
      if (!player) return;

      const content = document.getElementById('financial-detail-content');
      if (!content) return;

      content.innerHTML = `
        <div class="space-y-3">
          <div class="bg-clinical p-3 rounded">
            <div class="font-mono text-[10px] text-gray-500 uppercase mb-1">Player Name</div>
            <div class="font-display text-lg font-bold text-dark">${player.name}</div>
          </div>

          <div class="grid grid-cols-2 gap-2">
            <div class="bg-clinical p-3 rounded">
              <div class="font-mono text-[10px] text-gray-500 uppercase mb-1">Parent</div>
              <div class="font-mono text-xs text-dark">${player.parentName}</div>
            </div>
            <div class="bg-clinical p-3 rounded">
              <div class="font-mono text-[10px] text-gray-500 uppercase mb-1">Status</div>
              <div class="font-mono text-xs text-dark">${player.paidStatus || 'Pending'}</div>
            </div>
          </div>

          <div class="bg-clinical p-3 rounded">
            <div class="font-mono text-[10px] text-gray-500 uppercase mb-2">Current Balance</div>
            <input type="number" id="edit-balance" value="${player.balance}" step="0.01" class="w-full border border-borderLight px-2 py-1 font-mono text-sm outline-none focus:border-brand">
            <button onclick="saveBalanceEdit(${playerId})" class="mt-2 w-full bg-dark text-white px-2 py-1 font-mono text-[10px] uppercase font-bold hover:bg-brand hover:text-dark transition-all">
              Save Changes
            </button>
          </div>

          <div class="bg-yellow-50 border border-yellow-200 p-3 rounded font-mono text-[10px]">
            <div class="font-bold text-yellow-900 mb-1">Payment History</div>
            <div class="text-yellow-800 text-[9px]">Initial balance: $399.00<br>Last updated: Today</div>
          </div>
        </div>
      `;

      const markPaidBtn = document.getElementById('mark-paid-btn');
      if (markPaidBtn) {
        markPaidBtn.onclick = () => markPlayerAsPaid(playerId);
      }
    }

    function saveBalanceEdit(playerId) {
      const newBalance = parseFloat(document.getElementById('edit-balance').value);
      if (isNaN(newBalance) || newBalance < 0) {
        alert('Please enter a valid balance amount');
        return;
      }

      const player = STATE.players.find(p => p.id === playerId);
      if (player) {
        player.balance = newBalance;
        renderFinancialDetail(playerId);
        renderDirectorDashboard();
      }
    }

    function createNewAthlete(e) {
      e.preventDefault();
      const capLimit = getTierCap(STATE.currentTier);
      if (STATE.players.length >= capLimit) return;

      const nameField = document.getElementById('new-p-name');
      const dobField = document.getElementById('new-p-dob');
      if (!nameField || !dobField) return;

      const newId = STATE.players.length ? Math.max(...STATE.players.map(p => p.id)) + 1 : 1;
      const targetDivisions = [DIVISION_NODES[Math.floor(Math.random() * DIVISION_NODES.length)]];

      STATE.players.push({
        id: newId,
        name: nameField.value.trim(),
        jersey: Math.floor(Math.random() * 99).toString(),
        position: 'Utility Guard',
        dob: dobField.value,
        teams: targetDivisions,
        balance: 399.00,
        status: 'Active',
        parentName: 'Internal Administrative Addition',
        parentEmail: 'admin-override@athleteiqapp.com',
        parentPhone: '',
        paidStatus: 'Pending'
      });

      nameField.value = '';
      dobField.value = '';
      renderDirectorDashboard();
    }

    function refreshEventMatrixUI() {
      const mContainer = document.getElementById('division-badge-matrix');
      if(!mContainer) return;
      mContainer.innerHTML = '';

      DIVISION_NODES.forEach(divName => {
        const isSelected = selectedDivisionsForEvent.includes(divName);
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.onclick = () => {
          const idx = selectedDivisionsForEvent.indexOf(divName);
          if (idx > -1) {
            selectedDivisionsForEvent.splice(idx, 1);
          } else {
            selectedDivisionsForEvent.push(divName);
          }
          refreshEventMatrixUI();
        };
        btn.className = isSelected
          ? "bg-dark text-white font-mono text-[10px] font-bold px-2 py-1 border border-dark"
          : "bg-white text-gray-400 font-mono text-[10px] px-2 py-1 border border-borderDark hover:text-dark hover:border-dark";
        btn.innerText = divName;
        mContainer.appendChild(btn);
      });
    }

    function handleCreateEvent(e) {
      e.preventDefault();
      const titleEl = document.getElementById('evt-title');
      const typeEl = document.getElementById('evt-type');
      const locEl = document.getElementById('evt-loc');
      const startEl = document.getElementById('evt-start');
      const endEl = document.getElementById('evt-end');
      const recurringEl = document.getElementById('evt-recurring');

      if(!titleEl || !selectedDivisionsForEvent.length) {
        alert('Please specify an event title and select at least one division target.');
        return;
      }

      const newEvt = {
        id: Date.now(),
        title: titleEl.value.trim(),
        type: typeEl.value,
        location: locEl.value.trim(),
        start: startEl.value,
        end: endEl.value,
        divisions: [...selectedDivisionsForEvent],
        recurring: recurringEl.value
      };

      STATE.events.push(newEvt);
      titleEl.value = '';
      locEl.value = '';
      startEl.value = '';
      endEl.value = '';
      selectedDivisionsForEvent = ['9U'];

      refreshEventMatrixUI();
      renderDirectorDashboard();
      alert('Event published successfully. Recipient tracking matrices processed.');
    }

    function launchOverrideModal(pId, pName, currentBal) {
      STATE.modal.show = true;
      STATE.modal.playerId = pId;
      document.getElementById('modal-lbl-action').innerText = "Balance Manipulation Node";
      document.getElementById('modal-lbl-name').innerText = pName;
      document.getElementById('modal-override-input').value = currentBal;
      document.getElementById('destruction-modal-layer').classList.remove('hidden');
      document.getElementById('destruction-modal-layer').classList.add('flex');
    }

    function dismissOverrideModal() {
      STATE.modal.show = false;
      STATE.modal.playerId = null;
      document.getElementById('destruction-modal-layer').classList.add('hidden');
      document.getElementById('destruction-modal-layer').classList.remove('flex');
    }

    function commitOverrideModal() {
      const inputVal = parseFloat(document.getElementById('modal-override-input').value);
      if(isNaN(inputVal) || inputVal < 0) {
        alert('Please assign a valid numerical statement amount.');
        return;
      }

      const player = STATE.players.find(p => p.id === STATE.modal.playerId);
      if(player) {
        player.balance = inputVal;
      }
      dismissOverrideModal();
      renderDirectorDashboard();
    }

    function renderPlayerDashboard() {
      if (STATE.players.length === 0) {
        document.getElementById('player-profile-name').innerText = 'No Players';
        return;
      }

      const targetAthlete = STATE.players[STATE.players.length - 1] || STATE.players[0];

      document.getElementById('player-profile-name').innerText = targetAthlete.name;
      document.getElementById('player-profile-jersey').innerText = `#${targetAthlete.jersey}`;
      document.getElementById('player-profile-pos').innerText = targetAthlete.position.toUpperCase();
      document.getElementById('player-profile-teams').innerText = targetAthlete.teams.join(' & ');
      document.getElementById('player-profile-balance').innerText = targetAthlete.balance === 0 ? '$0.00' : `$${targetAthlete.balance.toFixed(2)}`;

      if(targetAthlete.balance > 0) {
        document.getElementById('player-profile-balance').className = "font-display text-2xl font-bold text-red-700 mt-1";
      } else {
        document.getElementById('player-profile-balance').className = "font-display text-2xl font-bold text-gray-500 mt-1";
      }

      const feedContainer = document.getElementById('player-events-feed');
      if(!feedContainer) return;
      feedContainer.innerHTML = '';

      const parentEvents = STATE.events.filter(evt =>
        evt.divisions.some(d => targetAthlete.teams.includes(d))
      );

      if(!parentEvents.length) {
        feedContainer.innerHTML = `<div class="font-mono text-xs text-gray-400 p-2 text-center">No Upcoming Events Logged for Assigned Division Brackets</div>`;
        return;
      }

      parentEvents.forEach(evt => {
        const div = document.createElement('div');
        div.className = "p-3 border border-borderLight bg-clinical font-mono text-xs flex justify-between items-center flex-wrap gap-2";
        div.innerHTML = `
          <div>
            <strong class="text-dark block font-bold uppercase">${evt.title} (${evt.type})</strong>
            <span class="text-gray-400 text-[10px]">Facility Location: ${evt.location}</span>
          </div>
          <div class="text-right text-[11px] font-bold text-dark">
            ${evt.start} - ${evt.end}
          </div>
        `;
        feedContainer.appendChild(div);
      });
    }

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024) {
        const mobileNav = document.getElementById('mobile-sidebar');
        if (mobileNav) mobileNav.classList.add('hidden');
        closeMobileMenu();
      }
    });

    switchDirectorTab('onboarding');
    refreshEventMatrixUI();
  </script>

  <footer class="mt-auto border-t border-borderLight bg-clinical py-6 px-4 text-center font-mono text-[10px] text-gray-400 uppercase tracking-widest">
    © 2026 AthleteIQ Internal Operations Hub. All Channels Secured.
  </footer>

</body>
</html>
