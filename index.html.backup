          <div class="text-gray-500 text-[10px]">Up to 49 players (Most Popular)</div>
        </button>
        <button onclick="changeSubscriptionTier('TIER_3'); closePlanModal();" class="w-full text-left p-3 border border-borderLight hover:bg-clinical transition-colors font-mono text-xs">
          <div class="font-bold text-dark">Large Organization — $499/month</div>
          <div class="text-gray-500 text-[10px]">Up to 99 players</div>
        </button>
      </div>
      <button onclick="closePlanModal()" class="w-full border border-dark py-2 font-mono text-[11px] uppercase font-bold text-dark hover:bg-dark hover:text-white transition-colors">
